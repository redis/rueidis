        }
      }
    ],
    "reply_schema": {
      "anyOf": [
        {
          "description": "Array of matching indexes.",
          "type": "array",
          "items": {
            "type": "integer",
            "description": "Index of a matching element"
          }
        },
        {
          "description": "Array of [index, value] pairs. Returned in case `WITHVALUES` was used.",
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              {
                "type": "integer",
                "description": "Index of a matching element"
              },
              {
                "type": "string",
                "description": "Value at that index"
              }
            ]
          }
        }
      ]
    },
